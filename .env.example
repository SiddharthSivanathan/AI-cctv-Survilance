# ============================================================
# VisionOps AI — Environment Configuration (example)
# Copy to .env and fill in. NEVER commit real secrets.
# ============================================================

# ---------- General ----------
NODE_ENV=development
ENVIRONMENT=development
LOG_LEVEL=INFO

# ---------- API (FastAPI) ----------
API_HOST=0.0.0.0
API_PORT=8000
API_V1_PREFIX=/api/v1
# CORS: comma-separated origins
CORS_ORIGINS=http://localhost:3000

# ---------- Security (generate strong values in prod) ----------
# openssl rand -hex 32
SECRET_KEY=change-me-in-production-please-use-openssl-rand
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ---------- PostgreSQL + TimescaleDB ----------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=visionops
POSTGRES_PASSWORD=visionops_dev_password
POSTGRES_DB=visionops
# Assembled async URL used by SQLAlchemy
DATABASE_URL=postgresql+asyncpg://visionops:visionops_dev_password@postgres:5432/visionops

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---------- Object Storage (MinIO / S3) ----------
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=visionops
S3_SECRET_KEY=visionops_dev_password
S3_BUCKET=visionops-media
S3_REGION=us-east-1

# ---------- Frontend (Next.js) ----------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=VisionOps AI

# ---------- AI Engine ----------
AI_DEVICE=cpu            # cpu | cuda
AI_MODEL_DIR=/models
AI_DEFAULT_FPS=2

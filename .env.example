# ============================================================
# VisionOps AI — Environment Configuration (example)
# Copy to .env and fill in. NEVER commit real secrets.
# ============================================================

# ---------- General ----------
NODE_ENV=development
ENVIRONMENT=development
LOG_LEVEL=INFO

# ---------- API (FastAPI) ----------
API_HOST=0.0.0.0
API_PORT=8000
API_V1_PREFIX=/api/v1
# CORS: comma-separated origins
CORS_ORIGINS=http://localhost:3000

# ---------- Security (generate strong values in prod) ----------
# openssl rand -hex 32
SECRET_KEY=change-me-in-production-please-use-openssl-rand
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
# RS256 keypair. Generate with: bash scripts/generate_keys.sh
# Provide a filesystem path (recommended) OR inline PEM. In development, if
# neither is set an ephemeral keypair is generated automatically.
JWT_PRIVATE_KEY_PATH=apps/api/keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=apps/api/keys/jwt_public.pem

# ---------- Email verification / password reset ----------
EMAIL_VERIFICATION_EXPIRE_HOURS=24
PASSWORD_RESET_EXPIRE_HOURS=2
EMAIL_FROM=no-reply@visionops.ai
# Frontend base URL used to build verification / reset links
FRONTEND_URL=http://localhost:3000

# ---------- Credential encryption (camera RTSP secrets) ----------
# Fernet key: python -c "import base64,os;print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
CREDENTIALS_ENCRYPTION_KEY=hkuXDBkzTIAaF56qfUDC8jaqCrrYh2XIZREFX5SGxi4=

# ---------- Internal service auth + cameras ----------
INTERNAL_API_TOKEN=change-me-internal-token
CAMERA_OFFLINE_THRESHOLD_SECONDS=300
RTSP_PROBE_TIMEOUT_SECONDS=12
# Worker -> API base URL for the health sweep (inside compose network)
API_INTERNAL_URL=http://api:8000

# ---------- Live streaming (MediaMTX + Go gateway) ----------
# HMAC secret shared between the API (token issuer) and gateway (verifier)
STREAM_JWT_SECRET=change-me-stream-secret
STREAM_TOKEN_TTL_SECONDS=60
# API -> gateway (internal compose network) and browser-facing gateway URL
GATEWAY_INTERNAL_URL=http://gateway:8080
GATEWAY_PUBLIC_URL=http://localhost:8080
GATEWAY_CORS_ORIGIN=http://localhost:3000

# ---------- PostgreSQL + TimescaleDB ----------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=visionops
POSTGRES_PASSWORD=visionops_dev_password
POSTGRES_DB=visionops
# Assembled async URL used by SQLAlchemy
DATABASE_URL=postgresql+asyncpg://visionops:visionops_dev_password@postgres:5432/visionops

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---------- Object Storage (MinIO / S3) ----------
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=visionops
S3_SECRET_KEY=visionops_dev_password
S3_BUCKET=visionops-media
S3_REGION=us-east-1

# ---------- Frontend (Next.js) ----------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=VisionOps AI

# ---------- AI Engine ----------
AI_DEVICE=cpu            # cpu | cuda
AI_MODEL_DIR=/models
AI_DEFAULT_FPS=2

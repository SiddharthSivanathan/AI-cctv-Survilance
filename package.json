{
  "name": "visionops-ai",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered Video Intelligence SaaS Platform",
  "author": "VisionOps AI",
  "license": "MIT",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ],
    "apps/api/**/*.py": [
      "bash -c 'cd apps/api && ruff check --fix'"
    ],
    "apps/ai-engine/**/*.py": [
      "bash -c 'cd apps/ai-engine && ruff check --fix'"
    ],
    "apps/worker/**/*.py": [
      "bash -c 'cd apps/worker && ruff check --fix'"
    ]
  }
}

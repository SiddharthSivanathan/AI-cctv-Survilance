{
  "name": "@visionops/utils",
  "version": "0.1.0",
  "private": true,
  "description": "Shared framework-agnostic utilities for VisionOps AI",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {

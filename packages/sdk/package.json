    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@visionops/types": "workspace:*"
  },
  "devDependencies": {
    "@visionops/config": "workspace:*",
    "eslint": "^9.11.1",
    "typescript": "^5.6.2"
  }
}

{
  "name": "@visionops/sdk",
  "version": "0.1.0",
  "private": true,
  "description": "Internal typed SDK/client for the VisionOps AI REST API",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
